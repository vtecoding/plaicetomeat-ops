# Supabase
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional SMS provider. Leave empty to keep SMS notifications off.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SMS master switch. Must be "true" AND a provider configured before any real
# SMS is attempted. Default OFF -> all SMS is recorded honestly as "disabled".
SMS_SENDING_ENABLED=false

# Safe test mode (local/staging only). When "true", checkout can submit
# visibly-marked TEST orders that never trigger real SMS. Keep OFF in production.
CHECKOUT_TEST_MODE_ENABLED=false
REALTIME_MODE=auto
NEXT_PUBLIC_CHECKOUT_TEST_MODE=false

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BRANCH_SLUG=wylde-green
RELEASE_REPORT_MODE=local
# Never set MIGRATION_DRIFT_CHECK_MODE=local|dev in release/CI mode.

# Runtime
NODE_ENV=development
