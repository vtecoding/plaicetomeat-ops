# Supabase
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional SMS provider. Leave empty to keep SMS notifications off.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SMS master switch. Must be "true" AND a provider configured before any real
# SMS is attempted. Default OFF -> all SMS is recorded honestly as "disabled".
SMS_SENDING_ENABLED=false

# Safe test mode (local/staging only). When "true", checkout can submit
# visibly-marked TEST orders that never trigger real SMS. Keep OFF in production.
CHECKOUT_TEST_MODE_ENABLED=false
REALTIME_MODE=auto
NEXT_PUBLIC_CHECKOUT_TEST_MODE=false

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BRANCH_SLUG=wylde-green
# Canonical storefront branch (V12.7). REQUIRED in production: without it the
# storefront returns CONFIGURATION_REQUIRED instead of guessing a branch. Either
# variable works; the server-only form is preferred.
CANONICAL_BRANCH_ID=
NEXT_PUBLIC_CANONICAL_BRANCH_ID=
RELEASE_REPORT_MODE=local
# Never set MIGRATION_DRIFT_CHECK_MODE=local|dev in release/CI mode.

# Demo data is NEVER used in production. Setting this to "true" re-enables demo
# fallback; leave unset/false outside local development.
ALLOW_DEMO_DATA=false

# Optional: V12.8 alert webhook sink. Leave empty to use the console sink only.
ALERT_WEBHOOK_URL=

# Security secrets (>= 32 chars). Required in production — no insecure fallback.
# ORDER_ACCESS_SECRET signs the public order-access cookie. STAFF_SESSION_SECRET
# signs the staff session envelope; if unset it falls back to ORDER_ACCESS_SECRET.
ORDER_ACCESS_SECRET=
STAFF_SESSION_SECRET=

# Runtime
NODE_ENV=development
