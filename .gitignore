# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# local Codex/dev server logs
.codex-devserver*.log

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local dev/verify artefacts
audit-results/devserver*.log
audit-results/_*
/dist

# large audit evidence bundles (kept locally; sanitized bundle lives in audit/)
/docs/full-audit-pack/
/docs/full-audit-pack-v11/
/screenshots-v11/
/screenshots-v11.zip
/plaicetomeat-v11-source.zip

# backup archives — encrypted .backup.enc files are stored as GitHub Actions artifacts.
# Raw dumps are deleted after encryption and must never be committed.
/backups/
